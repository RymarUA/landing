# ─────────────────────────────────────────────────────────────
# Environment Variables Template
# Copy this to .env.local for your environment

# Basic configuration
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=FamilyHub Market
NEXT_PUBLIC_SITE_DESCRIPTION=FamilyHub Market — інтернет-магазин якісних товарів для всієї родини

# ── Public URL ────────────────────────────────────────────────
# Used in WayForPay returnUrl / serviceUrl generation.
# Local dev: http://localhost:3000
# Production: http://familyhub.com.ua/

# ── WayForPay ─────────────────────────────────────────────────
# Your WayForPay merchant account name (e.g. FamilyHubMarket_UA)
WAYFORPAY_MERCHANT_ACCOUNT=

# Your store domain registered in WayForPay cabinet (e.g. familyhubmarket.com)
WAYFORPAY_MERCHANT_DOMAIN=

# HMAC-MD5 secret key from WayForPay cabinet → Settings → API keys
WAYFORPAY_SECRET_KEY=

# ── Sitniks CRM ───────────────────────────────────────────────
# Base URL of your Sitniks account API (NO trailing slash)
# Example: https://my-store.sitniks.com/api/v1
SITNIKS_API_URL=

# Bearer token from Sitniks → Settings → API
SITNIKS_API_KEY=

# Optional shared secret for /api/sitniks-webhook verification
# Set the same value in Sitniks → Settings → Webhook → Secret header
SITNIKS_WEBHOOK_SECRET=

# ── Sitniks — каталог товарів та розширені можливості ──────────
# Знайти ID в Sitniks: Налаштування → відповідний розділ → ID в URL або таблиці
SITNIKS_NP_INTEGRATION_ID=         # ID інтеграції Нової Пошти (Налаштування → Інтеграції → Нова Пошта)
SITNIKS_SALES_CHANNEL_ID=          # ID каналу "Сайт" (Налаштування → Канали продажів)
SITNIKS_NEW_STATUS_ID=             # ID статусу "Новий" (для COD замовлень) (Налаштування → Статуси замовлень)
SITNIKS_PENDING_PAYMENT_STATUS_ID= # ID статусу "Очікує оплати" (для онлайн-оплати)
SITNIKS_PAID_STATUS_ID=            # ID статусу "Оплачено" (встановлюється після успішної оплати)

# Розширені можливості (автоматично):
# ✅ Email клієнта (опціонально в формі)
# ✅ Коментар клієнта до замовлення
# ✅ Автоматичний розрахунок ваги з товарів
# ✅ UTM-трекінг (source, medium, campaign)
# ✅ Referrer tracking
# ✅ Розширений коментар менеджера з аналітикою
# ✅ External ID для уникнення дублікатів
# 
# Детальніше: docs/SITNIKS_ENHANCED_FEATURES.md

# ── Persistent KV (Redis / Vercel KV) ──────────────────────────
# Required for OTP, abandoned cart, and rate limiting persistence.
# If omitted, the app falls back to in-memory storage (data resets on restart).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# ── Telegram ──────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Target chat/channel ID (group: -100xxxxxxxxxx, private: your numeric user ID)
TELEGRAM_CHAT_ID=

# ── Resend (Email) ────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address (must match a domain verified in Resend)
EMAIL_FROM=FamilyHub Market <noreply@familyhubmarket.com>

# Admin email to receive order copies
EMAIL_ADMIN=admin@familyhubmarket.com

# ── Instagram Catalog (optional — mock is used without these) ─
# Long-lived User Access Token from Meta for Developers
INSTAGRAM_ACCESS_TOKEN=

# Numeric Instagram Business/Creator account ID
INSTAGRAM_USER_ID=

# ── Admin API protection ──────────────────────────────────────
# A random secret for POST /api/notify-shipping endpoint
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# ── Admin Panel Password ────────────────────────────────────────
# Password for accessing /admin page
# Generate a strong password and keep it secret
NEXT_PUBLIC_ADMIN_PASSWORD=

# ── Analytics ─────────────────────────────────────────────────
# Meta Pixel numeric ID from Meta Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# ── Personal Cabinet (OTP Auth) ───────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 64
# Default is a dev fallback (CHANGE IN PRODUCTION!)
JWT_SECRET=

# ── SMS Provider for OTP ───────────────────────────────────────
# Choose provider: turbosms (recommended for Ukraine) or twilio
SMS_PROVIDER=turbosms

# TurboSMS (Ukrainian provider)
# Get from: https://turbosms.ua/
TURBOSMS_TOKEN=your_api_token_here
TURBOSMS_SENDER=your_sender_name_here

# Twilio (International provider) - alternative to TurboSMS
# Get from: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ── Abandoned Cart ────────────────────────────────────────────
# Delay in milliseconds before sending abandoned cart notification
# Default: 1800000 (30 minutes)
# WARNING: Current implementation uses in-memory timers and does NOT work on Vercel
# For production, implement Redis-based solution (see app/api/abandoned-cart/route.ts)
ABANDONED_CART_DELAY_MS=1800000
