# ─────────────────────────────────────────────────────────────
# FamilyHub Market — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Public URL ────────────────────────────────────────────────
# Used in WayForPay returnUrl / serviceUrl generation.
# Local dev: http://localhost:3000
# Production: https://familyhubmarket.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── WayForPay ─────────────────────────────────────────────────
# Your WayForPay merchant account name (e.g. FamilyHubMarket_UA)
WAYFORPAY_MERCHANT_ACCOUNT=

# Your store domain registered in WayForPay cabinet (e.g. familyhubmarket.com)
WAYFORPAY_MERCHANT_DOMAIN=

# HMAC-MD5 secret key from WayForPay cabinet → Settings → API keys
WAYFORPAY_SECRET_KEY=

# ── Sitniks CRM ───────────────────────────────────────────────
# Base URL of your Sitniks account API (NO trailing slash)
# Example: https://my-store.sitniks.com/api/v1
SITNIKS_API_URL=

# Bearer token from Sitniks → Settings → API
SITNIKS_API_KEY=

# ── Instagram Catalog (optional — mock is used without these) ─
# Long-lived User Access Token from Meta for Developers
INSTAGRAM_ACCESS_TOKEN=

# Numeric Instagram Business/Creator account ID
INSTAGRAM_USER_ID=

# ── Telegram (optional — legacy fallback notifications) ───────
# Only needed if you want Telegram notifications in addition to Sitniks.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
