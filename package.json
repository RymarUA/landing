{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "echo '✅ Dependencies installed successfully'",
    "prebuild": "node scripts/remove-cdn-for-vercel.cjs",
    "dev:fast": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev",
    "dev:turbo": "next dev --turbo",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build",
    "build:emergency": "node scripts/emergency-build.js",
    "build:fast": "cross-env NEXT_TELEMETRY_DISABLED=1 NEXT_SKIP_TYPE_CHECK=1 NEXT_SKIP_LINTING=1 next build",
    "start": "next start",
    "start:dev": "next start",
    "deploy:check": "bash scripts/check-env.sh",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "bash scripts/test-checkout-integration.sh",
    "test:integration:windows": "powershell -File scripts/test-checkout-integration.ps1",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" || echo 'Prettier not installed'",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" || echo 'Prettier not installed'",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mapbox/rehype-prism": "^0.9.0",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "15.5.12",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.2",
    "@tabler/icons-react": "^3.36.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "0.6.5",
    "date-fns": "^4.1.0",
    "fast-glob": "^3.3.3",
    "framer-motion": "^12.29.2",
    "geist": "^1.5.1",
    "lucide-react": "^0.563.0",
    "minimatch": "10.0.0",
    "next": "15.5.12",
    "next-themes": "^0.4.6",
    "node-fetch": "2.7.0",
    "path-to-regexp": "6.3.0",
    "prismjs": "^1.30.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "react-wrap-balancer": "1.1.1",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.1",
    "sharp": "0.34.5",
    "styled-jsx": "^5.1.6",
    "tailwind-merge": "^3.4.0",
    "tar": "7.0.1",
    "typescript": "^5",
    "undici": "6.23.0",
    "web-vitals": "5.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.9.11",
    "cross-env": "^7.0.3",
    "eslint": "9.0.0",
    "eslint-config-next": "15.5.12",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.1.2",
    "tsx": "^4.19.2",
    "vercel": "^50.0.0"
  },
  "overrides": {
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1"
  }
}
